generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_logs {
  id            BigInt          @id @default(autoincrement())
  org_id        String?         @db.Uuid
  actor_user_id String?         @db.Uuid
  actor_role    user_role_enum?
  action        String          @db.VarChar(100)
  target_type   String          @db.VarChar(50)
  target_id     String          @db.Uuid
  diff          Json?
  metadata      Json?
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  users         users?          @relation(fields: [actor_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organisations organisations?  @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([org_id, created_at(sort: Desc)], map: "idx_audit_logs_org")
  @@index([target_type, target_id], map: "idx_audit_logs_target")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model file_attachments {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id            String        @db.Uuid
  uploaded_by       String        @db.Uuid
  bucket            String        @db.VarChar(50)
  file_path         String        @unique @db.VarChar(500)
  original_filename String?       @db.VarChar(255)
  mime_type         String        @db.VarChar(100)
  size_bytes        Int
  created_at        DateTime      @default(now()) @db.Timestamptz(6)
  organisations     organisations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users             users         @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments          payments[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model invoices {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id               String              @db.Uuid
  tenancy_id           String              @db.Uuid
  unit_id              String              @db.Uuid
  tenant_user_id       String              @db.Uuid
  invoice_number       String              @unique @db.VarChar(50)
  billing_period_start DateTime            @db.Date
  billing_period_end   DateTime            @db.Date
  due_date             DateTime            @db.Date
  amount_due           Decimal             @db.Decimal(12, 2)
  amount_paid          Decimal             @default(0) @db.Decimal(12, 2)
  balance              Decimal?            @default(dbgenerated("(amount_due - amount_paid)")) @db.Decimal(12, 2)
  status               invoice_status_enum @default(DUE)
  notes                String?
  generated_by         String              @default("MANUAL") @db.VarChar(20)
  created_at           DateTime            @default(now()) @db.Timestamptz(6)
  updated_at           DateTime            @default(now()) @db.Timestamptz(6)
  organisations        organisations       @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenancies            tenancies           @relation(fields: [tenancy_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                users               @relation(fields: [tenant_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  units                units               @relation(fields: [unit_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments             payments?
  receipts             receipts[]

  @@unique([tenancy_id, billing_period_start])
  @@index([org_id], map: "idx_invoices_org")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model notifications {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id            String                 @db.Uuid
  recipient_user_id String                 @db.Uuid
  type              notification_type_enum
  title             String                 @db.VarChar(255)
  body              String
  reference_type    String?                @db.VarChar(50)
  reference_id      String?                @db.Uuid
  is_read           Boolean                @default(false)
  read_at           DateTime?              @db.Timestamptz(6)
  created_at        DateTime               @default(now()) @db.Timestamptz(6)
  organisations     organisations          @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users             users                  @relation(fields: [recipient_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model organisations {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String                    @db.VarChar(255)
  slug                    String                    @unique @db.VarChar(100)
  phone                   String?                   @db.VarChar(30)
  email                   String                    @unique @db.VarChar(255)
  country_code            String                    @default("RW") @db.Char(2)
  currency_code           String                    @default("RWF") @db.Char(3)
  timezone                String                    @default("Africa/Kigali") @db.VarChar(50)
  subscription_status     subscription_status_enum  @default(TRIAL)
  trial_ends_at           DateTime?                 @db.Timestamptz(6)
  is_active               Boolean                   @default(true)
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @db.Timestamptz(6)
  audit_logs              audit_logs[]
  file_attachments        file_attachments[]
  invoices                invoices[]
  notifications           notifications[]
  payments                payments[]
  properties              properties[]
  receipts                receipts[]
  subscriptions           subscriptions?
  tenancies               tenancies[]
  units                   units[]
  user_organisation_roles user_organisation_roles[]

  @@index([slug], map: "idx_organisations_slug")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payments {
  id                                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id                               String              @db.Uuid
  invoice_id                           String              @unique(map: "idx_payments_one_pending") @db.Uuid
  tenant_user_id                       String              @db.Uuid
  amount                               Decimal             @db.Decimal(12, 2)
  payment_method                       payment_method_enum
  transaction_id                       String?             @db.VarChar(100)
  proof_file_id                        String?             @db.Uuid
  status                               payment_status_enum @default(PENDING)
  rejection_reason                     String?
  reviewed_by                          String?             @db.Uuid
  reviewed_at                          DateTime?           @db.Timestamptz(6)
  submitted_at                         DateTime            @default(now()) @db.Timestamptz(6)
  created_at                           DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                           DateTime            @default(now()) @db.Timestamptz(6)
  invoices                             invoices            @relation(fields: [invoice_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organisations                        organisations       @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  file_attachments                     file_attachments?   @relation(fields: [proof_file_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_payments_reviewed_byTousers    users?              @relation("payments_reviewed_byTousers", fields: [reviewed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_payments_tenant_user_idTousers users               @relation("payments_tenant_user_idTousers", fields: [tenant_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  receipts                             receipts?

  @@unique([org_id, transaction_id], map: "idx_payments_txid_idempotency")
  @@index([org_id], map: "idx_payments_org")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model properties {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id        String             @db.Uuid
  name          String             @db.VarChar(255)
  property_type property_type_enum
  address_line1 String             @db.VarChar(255)
  address_line2 String?            @db.VarChar(255)
  city          String             @default("Kigali") @db.VarChar(100)
  district      String?            @db.VarChar(100)
  country_code  String             @default("RW") @db.Char(2)
  total_units   Int                @default(0)
  is_active     Boolean            @default(true)
  created_at    DateTime           @default(now()) @db.Timestamptz(6)
  updated_at    DateTime           @default(now()) @db.Timestamptz(6)
  organisations organisations      @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  units         units[]

  @@index([org_id], map: "idx_properties_org")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model receipts {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id          String        @db.Uuid
  payment_id      String        @unique @db.Uuid
  invoice_id      String        @db.Uuid
  tenant_user_id  String        @db.Uuid
  receipt_number  String        @unique @db.VarChar(50)
  file_path       String        @db.VarChar(500)
  file_size_bytes Int?
  generated_at    DateTime      @default(now()) @db.Timestamptz(6)
  download_count  Int           @default(0)
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  invoices        invoices      @relation(fields: [invoice_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organisations   organisations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payments        payments      @relation(fields: [payment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           users         @relation(fields: [tenant_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([org_id], map: "idx_receipts_org")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model refresh_tokens {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  token_hash  String    @unique @db.VarChar(255)
  expires_at  DateTime  @db.Timestamptz(6)
  revoked_at  DateTime? @db.Timestamptz(6)
  device_info String?   @db.VarChar(255)
  ip_address  String?   @db.Inet
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model subscription_tiers {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tier              subscription_tier_enum @unique
  max_units         Int
  max_properties    Int
  max_managers      Int
  has_whatsapp      Boolean                @default(false)
  has_kinyarwanda   Boolean                @default(false)
  has_api_access    Boolean                @default(false)
  monthly_price_rwf Decimal                @db.Decimal(10, 2)
  annual_price_rwf  Decimal                @db.Decimal(10, 2)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model subscriptions {
  id                   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id               String                   @unique @db.Uuid
  tier                 subscription_tier_enum
  billing_cycle        billing_cycle_enum       @default(MONTHLY)
  amount               Decimal                  @db.Decimal(10, 2)
  status               subscription_status_enum
  trial_ends_at        DateTime?                @db.Timestamptz(6)
  current_period_start DateTime?                @db.Timestamptz(6)
  current_period_end   DateTime?                @db.Timestamptz(6)
  cancelled_at         DateTime?                @db.Timestamptz(6)
  created_at           DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at           DateTime                 @default(now()) @db.Timestamptz(6)
  organisations        organisations            @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tenancies {
  id                                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id                                String              @db.Uuid
  unit_id                               String              @db.Uuid
  tenant_user_id                        String              @db.Uuid
  start_date                            DateTime            @db.Date
  end_date                              DateTime?           @db.Date
  agreed_rent                           Decimal             @db.Decimal(12, 2)
  deposit_amount                        Decimal             @default(0) @db.Decimal(12, 2)
  status                                tenancy_status_enum @default(ACTIVE)
  terminated_at                         DateTime?           @db.Timestamptz(6)
  terminated_by                         String?             @db.Uuid
  termination_reason                    String?
  created_by                            String              @db.Uuid
  created_at                            DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                            DateTime            @default(now()) @db.Timestamptz(6)
  invoices                              invoices[]
  users_tenancies_created_byTousers     users               @relation("tenancies_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organisations                         organisations       @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_tenancies_tenant_user_idTousers users               @relation("tenancies_tenant_user_idTousers", fields: [tenant_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_tenancies_terminated_byTousers  users?              @relation("tenancies_terminated_byTousers", fields: [terminated_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  units                                 units               @relation(fields: [unit_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([unit_id, status], map: "idx_tenancies_active_unit")
  @@index([org_id], map: "idx_tenancies_org")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model units {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id        String           @db.Uuid
  property_id   String           @db.Uuid
  unit_number   String           @db.VarChar(50)
  unit_type     unit_type_enum
  floor         Int?             @db.SmallInt
  monthly_rent  Decimal          @db.Decimal(12, 2)
  status        unit_status_enum @default(VACANT)
  description   String?
  is_active     Boolean          @default(true)
  created_at    DateTime         @default(now()) @db.Timestamptz(6)
  updated_at    DateTime         @default(now()) @db.Timestamptz(6)
  invoices      invoices[]
  tenancies     tenancies[]
  organisations organisations    @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  properties    properties       @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([property_id, unit_number])
  @@index([org_id], map: "idx_units_org")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_organisation_roles {
  id                                              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                                         String         @db.Uuid
  org_id                                          String         @db.Uuid
  role                                            user_role_enum
  status                                          role_status_enum @default(APPROVED)
  is_active                                       Boolean        @default(true)
  invited_by                                      String?        @db.Uuid
  invited_at                                      DateTime?      @db.Timestamptz(6)
  accepted_at                                     DateTime?      @db.Timestamptz(6)
  created_at                                      DateTime       @default(now()) @db.Timestamptz(6)
  invited_by_user                                 users?         @relation("user_organisation_roles_invited_byTousers", fields: [invited_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organisations                                   organisations  @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user                                            users          @relation("user_organisation_roles_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, org_id])
  @@index([org_id, role], map: "idx_uor_org_role")
  @@index([user_id], map: "idx_uor_user")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                                                                String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                                             String                    @unique @db.VarChar(255)
  phone                                                             String?                   @db.VarChar(30)
  full_name                                                         String                    @db.VarChar(255)
  password_hash                                                     String                    @db.VarChar(255)
  is_active                                                         Boolean                   @default(true)
  is_email_verified                                                 Boolean                   @default(false)
  last_login_at                                                     DateTime?                 @db.Timestamptz(6)
  preferred_language                                                String                    @default("en") @db.Char(2)
  two_fa_enabled                                                    Boolean                   @default(false)
  two_fa_secret                                                     String?                   @db.VarChar(255)
  created_at                                                        DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at                                                        DateTime                  @default(now()) @db.Timestamptz(6)
  audit_logs                                                        audit_logs[]
  file_attachments                                                  file_attachments[]
  invoices                                                          invoices[]
  notifications                                                     notifications[]
  payments_payments_reviewed_byTousers                              payments[]                @relation("payments_reviewed_byTousers")
  payments_payments_tenant_user_idTousers                           payments[]                @relation("payments_tenant_user_idTousers")
  receipts                                                          receipts[]
  refresh_tokens                                                    refresh_tokens[]
  tenancies_tenancies_created_byTousers                             tenancies[]               @relation("tenancies_created_byTousers")
  tenancies_tenancies_tenant_user_idTousers                         tenancies[]               @relation("tenancies_tenant_user_idTousers")
  tenancies_tenancies_terminated_byTousers                          tenancies[]               @relation("tenancies_terminated_byTousers")
  user_organisation_roles_invited                                   user_organisation_roles[] @relation("user_organisation_roles_invited_byTousers")
  user_organisation_roles                                           user_organisation_roles[] @relation("user_organisation_roles_user_idTousers")

  @@index([email], map: "idx_users_email")
}

enum billing_cycle_enum {
  MONTHLY
  ANNUAL
}

enum invoice_status_enum {
  DUE
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum notification_type_enum {
  PAYMENT_SUBMITTED
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  INVOICE_DUE
  INVOICE_OVERDUE
  RECEIPT_AVAILABLE
  SUBSCRIPTION_EXPIRING
}

enum payment_method_enum {
  MOMO
  BANK_TRANSFER
}

enum payment_status_enum {
  PENDING
  APPROVED
  REJECTED
}

enum property_type_enum {
  APARTMENT
  COMMERCIAL
  OFFICE
  KIOSK
  MIXED_USE
}

enum subscription_status_enum {
  TRIAL
  ACTIVE
  LAPSED
  CANCELLED
}

enum subscription_tier_enum {
  STARTER
  GROWTH
  PRO
}

enum tenancy_status_enum {
  ACTIVE
  TERMINATED
  EXPIRED
}

enum unit_status_enum {
  VACANT
  OCCUPIED
  MAINTENANCE
}

enum unit_type_enum {
  STUDIO
  ONE_BED    @map("1BED")
  TWO_BED    @map("2BED")
  THREE_BED    @map("3BED")
  KIOSK
  OFFICE
  OTHER
}

enum role_status_enum {
  PENDING
  APPROVED
  REJECTED
}

enum user_role_enum {
  OWNER
  MANAGER
  ACCOUNTANT
  TENANT
  SUPER_ADMIN
}
